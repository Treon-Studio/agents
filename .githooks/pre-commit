#!/usr/bin/env bash
#############################################################################
# Pre-commit hook - runs tests before allowing commit
# Install: ln -sf ../../.githooks/pre-commit .git/hooks/pre-commit
# Or: git config core.hooksPath .githooks
#############################################################################

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${YELLOW}Running pre-commit tests...${NC}"
echo ""

# Get the repo root
REPO_DIR="$(git rev-parse --show-toplevel)"
cd "$REPO_DIR"

FAILED=0

# Test 1: Shellcheck on shell scripts
echo -e "${YELLOW}1. Running shellcheck...${NC}"
if command -v shellcheck &>/dev/null; then
    if shellcheck install.sh update.sh scripts/*.sh 2>/dev/null; then
        echo -e "${GREEN}✓ Shellcheck passed${NC}"
    else
        echo -e "${RED}✗ Shellcheck failed${NC}"
        FAILED=1
    fi
else
    echo -e "${YELLOW}⚠ shellcheck not installed, skipping${NC}"
fi

echo ""

# Test 2: Integration tests
echo -e "${YELLOW}2. Running integration tests...${NC}"
if bash tests/integration.sh; then
    echo -e "${GREEN}✓ Integration tests passed${NC}"
else
    echo -e "${RED}✗ Integration tests failed${NC}"
    FAILED=1
fi

echo ""

if [ $FAILED -eq 0 ]; then
    echo -e "${GREEN}All pre-commit tests passed!${NC}"
    exit 0
else
    echo -e "${RED}Pre-commit tests failed. Fix issues before committing.${NC}"
    echo -e "${YELLOW}To bypass: git commit --no-verify${NC}"
    exit 1
fi