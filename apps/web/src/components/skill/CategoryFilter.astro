---
import { Icon } from "astro-icon/components";
import type { SkillCategory } from "@/types";

interface Props {
	categories: SkillCategory[];
	activeCategory?: string;
}

const { categories, activeCategory } = Astro.props;

const categoryLabels: Record<SkillCategory, string> = {
	design: "Design",
	engineering: "Engineering",
	data: "Data",
	writing: "Writing",
	product: "Product",
	business: "Business",
	education: "Education",
	science: "Science",
	ai: "AI",
	community: "Community",
};
---

<div class="mb-8 flex flex-wrap items-center gap-2">
	<a
		class={`flex items-center gap-1.5 rounded-full px-4 py-2 text-sm font-medium transition-colors ${
			!activeCategory
				? "bg-accent text-white"
				: "bg-zinc-100 text-muted hover:bg-zinc-200 dark:bg-zinc-800 dark:hover:bg-zinc-700"
		}`}
		href="/skills/"
	>
		<Icon class="h-4 w-4" name="mdi:apps" />
		All
	</a>

	{categories.map((cat) => (
		<a
			class={`flex items-center gap-1.5 rounded-full px-4 py-2 text-sm font-medium transition-colors ${
				activeCategory === cat
					? "bg-accent text-white"
					: "bg-zinc-100 text-muted hover:bg-zinc-200 dark:bg-zinc-800 dark:hover:bg-zinc-700"
			}`}
			href={`/skills/?category=${cat}`}
		>
			{categoryLabels[cat]}
		</a>
	))}
</div>