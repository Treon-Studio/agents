---
import type { CollectionEntry } from "astro:content";
import type { HTMLTag, Polymorphic } from "astro/types";
import { Icon } from "astro-icon/components";

type Props<Tag extends HTMLTag> = Polymorphic<{ as: Tag }> & {
	skill: CollectionEntry<"skill">;
};

const { as: Tag = "div", skill } = Astro.props;
const { data } = skill;

const categoryIcons: Record<string, string> = {
	design: "mdi:palette",
	engineering: "mdi:cog",
	data: "mdi:database",
	writing: "mdi:pen",
	product: "mdi:package-variant",
	business: "mdi:briefcase",
	education: "mdi:school",
	science: "mdi:flask",
	ai: "mdi:robot",
	community: "mdi:account-group",
};
---

<Tag
	class="group relative flex flex-col rounded-lg border border-zinc-200 bg-global-bg p-5 transition-all hover:border-accent hover:shadow-md dark:border-zinc-700 dark:bg-zinc-800/50"
	data-pagefind-body
>
	{data.featured && (
		<span class="absolute end-3 top-3 rounded-full bg-accent px-2 py-0.5 text-xs font-semibold text-white">
			Featured
		</span>
	)}

	<div class="mb-3 flex items-center gap-2">
		<span class="flex h-10 w-10 items-center justify-center rounded-lg bg-accent/10 text-accent">
			<Icon class="h-5 w-5" name={categoryIcons[data.category] || "mdi:star"} />
		</span>
		<span class="rounded bg-zinc-100 px-2 py-0.5 text-xs font-medium dark:bg-zinc-700">
			{data.category}
		</span>
	</div>

	<h3 class="mb-2 text-lg font-bold">
		<a
			class="cactus-link before:absolute before:inset-0 before:rounded-lg"
			href={`/skills/${skill.id}/`}
		>
			{data.title}
		</a>
	</h3>

	<p class="mb-4 line-clamp-2 flex-grow text-sm text-muted">
		{data.description}
	</p>

	<div class="mt-auto flex items-center justify-between">
		<div class="flex items-center gap-2">
			{data.authorUrl ? (
				<a
					class="text-xs font-medium text-accent hover:underline"
					href={data.authorUrl}
					target="_blank"
					rel="noreferrer"
				>
					{data.author}
				</a>
			) : (
				<span class="text-xs font-medium text-muted">{data.author}</span>
			)}
		</div>

		<a
			class="inline-flex items-center gap-1 text-sm font-semibold text-accent hover:text-accent/80"
			href={`/skills/${skill.id}/`}
		>
			View
			<Icon class="h-4 w-4" name="mdi:arrow-right" />
		</a>
	</div>

	{data.tags && data.tags.length > 0 && (
		<div class="mt-3 flex flex-wrap gap-1">
			{data.tags.slice(0, 3).map((tag: string) => (
				<span class="rounded bg-zinc-100 px-1.5 py-0.5 text-xs text-muted dark:bg-zinc-700">
					#{tag}
				</span>
			))}
		</div>
	)}
</Tag>