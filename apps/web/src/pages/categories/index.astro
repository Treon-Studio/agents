---

<BaseLayout meta={{ title: "Categories", description: "Browse skills by category" }}>
  <div class="mb-8">
    <h1 class="hero-title">Categories</h1>
    <p class="hero-subtitle">Explore skills organized by their primary category</p>
  </div>

  <div class="categories-grid">
    {categories
      .filter((c) => c.count > 0)
      .sort((a, b) => b.count - a.count)
      .map((cat) => (
        <a href={`/skills/?category=${cat.slug}`} class="category-card">
          <span class="category-icon">
            <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24">
              <path d={categoryIcons[cat.slug] || categoryIcons.design} />
            </svg>
          </span>
          <span class="category-name">{categoryLabels[cat.slug] || cat.slug}</span>
          <span class="category-count">{cat.count} skills</span>
        </a>
      ))}
  </div>
</BaseLayout>

<style>
  .hero-title {
    font-size: clamp(1.8rem, 5vw, 2.6rem);
    font-weight: 700;
    color: #f0f0f0;
    line-height: 1.2;
    margin-bottom: 12px;
  }

  .hero-subtitle {
    font-size: 1rem;
    color: #888;
    margin-bottom: 32px;
    line-height: 1.6;
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 16px;
  }

  .category-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: #141414;
    border: 1px solid #1e1e1e;
    padding: 24px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, background-color 0.15s;
    text-align: center;
  }

  .category-card:hover {
    border-color: #333;
    background: #111;
  }

  .category-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #555;
    margin-bottom: 12px;
  }

  .category-name {
    font-size: 1rem;
    font-weight: 700;
    color: #e8e8e8;
    margin-bottom: 4px;
  }

  .category-count {
    font-size: 0.75rem;
    color: #555;
  }
</style>